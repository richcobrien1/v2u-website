#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Read the commit message
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Check if commit message contains potential secrets or credentials
if echo "$COMMIT_MSG" | grep -Ei "(password|secret|api[_-]?key|token).*[:=].*[\w-]{8,}" > /dev/null 2>&1; then
  echo ""
  echo "⚠️  WARNING: Your commit message might contain credentials!"
  echo ""
  echo "Commit message should not include actual secret values."
  echo "Consider rephrasing to avoid exposing sensitive information."
  echo ""
  echo "Current message:"
  echo "$COMMIT_MSG"
  echo ""
  read -p "Continue anyway? (y/N) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

echo "✅ Commit message looks safe"
